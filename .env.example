# .env.example — copy to .env and fill in your values
# cp .env.example .env

# Required: your Anthropic API key for the AI diagnostic layer
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL connection (matches docker-compose defaults)
DATABASE_URL=postgresql://sentinel:sentinel_pass@localhost:5432/cloudops

# Node hosts (comma-separated host:port pairs)
NODE_HOSTS=node-01:9100,node-02:9100,node-03:9100,node-04:9100,node-05:9100

# Patching config
PATCH_TYPE=security
BATCH_SIZE=2
ROLLBACK_THRESHOLD=0.20
PATCH_DRY_RUN=true
